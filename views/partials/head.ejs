<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= content.brand.name %> <%= content.brand.tagScript %> — <%= content.brand.tagline %></title>
  <meta name="description" content="<%= content.brand.description %>">

  <!-- Preconnect -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Great+Vibes&family=Instrument+Sans:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

  <!-- Scroll Progress Bar -->
  <div class="scroll-progress" id="scroll-progress"></div>

  <!-- Custom Cursor -->
  <div class="cursor" id="cursor">
    <div class="cursor-dot"></div>
    <div class="cursor-ring"></div>
  </div>

  <!-- Back to Top -->
  <button class="back-to-top" id="back-to-top" aria-label="Back to top">
    <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
      <path d="M8 14V2M8 2L2 8M8 2L14 8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>

  <!-- Page Loader — Cinematic Curtain Reveal -->
  <div class="loader" id="loader">
    <div class="loader-curtain-left"></div>
    <div class="loader-curtain-right"></div>
    <div class="loader-inner">
      <span class="loader-brand">PAKNITS</span>
      <span class="loader-script script"></span>
      <div class="loader-bar"><div class="loader-fill"></div></div>
    </div>
  </div>
