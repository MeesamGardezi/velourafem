<footer class="footer" id="contact">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand reveal">
        <a href="#" class="nav-logo footer-logo">
          <span class="nav-logo-text"><%= content.brand.name %></span>
          <span class="script nav-logo-script"><%= content.brand.tagScript %></span>
        </a>
        <p class="footer-desc"><%= content.brand.description %> Established <%= content.brand.established %>.</p>
        <div class="footer-social">
          <a href="#" class="social-link">In</a>
          <a href="#" class="social-link">Pi</a>
          <a href="#" class="social-link">Tw</a>
        </div>
      </div>

      <% content.footer.columns.forEach(function(col) { %>
        <div class="footer-col reveal">
          <h4 class="footer-col-title"><%= col.heading %></h4>
          <ul class="footer-col-list">
            <% col.links.forEach(function(link) { %>
              <li><a href="<%= link.href %>" class="footer-link"><%= link.label %></a></li>
            <% }); %>
          </ul>
        </div>
      <% }); %>
    </div>

    <div class="footer-bottom">
      <p class="footer-legal"><%= content.footer.legal %></p>
      <p class="footer-made">Crafted with intention.</p>
    </div>
  </div>
</footer>
