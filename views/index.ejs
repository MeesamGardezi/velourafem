<%- include('partials/head') %>

<%- include('partials/nav') %>

<main>

  <!-- ═══ HERO ═══ -->
  <section class="hero" id="hero">
    <div class="hero-bg">
      <div class="hero-grain"></div>
      <div class="hero-orb hero-orb-1"></div>
      <div class="hero-orb hero-orb-2"></div>
      <div class="hero-orb hero-orb-3"></div>
    </div>
    <div class="hero-border"></div>

    <div class="hero-content">
      <p class="hero-eyebrow"><%= content.hero.eyebrow %></p>

      <h1 class="hero-title">
        <span class="hero-title-line"><%= content.hero.headline %></span>
        <span class="hero-title-script script"><%= content.hero.headlineAccent %></span>
      </h1>

      <p class="hero-sub"><%= content.hero.subheadline %></p>

      <div class="hero-actions">
        <a href="<%= content.hero.ctaPrimary.href %>" class="btn btn-terracotta">
          <%= content.hero.ctaPrimary.label %>
        </a>
        <a href="<%= content.hero.ctaSecondary.href %>" class="btn btn-ghost-light">
          <%= content.hero.ctaSecondary.label %>
        </a>
      </div>

      <div class="hero-scroll">
        <div class="hero-scroll-line"></div>
        <span><%= content.hero.scrollLabel %></span>
      </div>
    </div>
  </section>

  <!-- ═══ MARQUEE ═══ -->
  <div class="marquee-wrap">
    <div class="marquee-track">
      <% for (let i = 0; i < 3; i++) { %>
        <% content.marquee.forEach(function(item) { %>
          <span class="marquee-item"><%= item %></span>
          <span class="marquee-sep">◈</span>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- ═══ STATS ═══ -->
  <section class="stats-section">
    <div class="stats-grid">
      <% content.stats.forEach(function(stat) { %>
        <div class="stat-item">
          <span class="stat-value" data-value="<%= stat.value %>"><%= stat.value %></span>
          <span class="stat-label"><%= stat.label %></span>
        </div>
      <% }); %>
    </div>
  </section>

  <!-- ═══ PHILOSOPHY ═══ -->
  <section class="philosophy" id="philosophy">
    <div class="philosophy-inner">
      <div class="philosophy-header">
        <p class="section-eyebrow"><%= content.philosophy.eyebrow %></p>
        <h2 class="section-title">
          <%= content.philosophy.title %>
          <em class="script-heading"><%= content.philosophy.titleAccent %></em>
        </h2>
        <p class="section-subtitle"><%= content.philosophy.subtitle %></p>
      </div>

      <div class="pillars">
        <% content.philosophy.pillars.forEach(function(pillar, i) { %>
          <div class="pillar">
            <div class="pillar-icon"><%= pillar.icon %></div>
            <h3 class="pillar-title"><%= pillar.title %></h3>
            <p class="pillar-body"><%= pillar.body %></p>
            <div class="pillar-line"></div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ── Section Divider ── -->
  <div class="section-divider">
    <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
      <line class="divider-line" x1="0" y1="1" x2="1200" y2="1" stroke="currentColor" stroke-width="1"/>
    </svg>
  </div>

  <!-- ═══ COLLECTION ═══ -->
  <section class="collection" id="collection">
    <div class="collection-inner">
      <div class="collection-header">
        <p class="section-eyebrow"><%= content.collection.eyebrow %></p>
        <h2 class="section-title"><em><%= content.collection.title %></em></h2>
        <p class="section-subtitle"><%= content.collection.subtitle %></p>
      </div>

      <div class="cards">
        <% content.collection.items.forEach(function(item, i) { %>
          <article class="card">
            <div class="card-img card-img--<%= item.color %>">
              <!-- SVG Decorative Pattern -->
              <div class="card-svg-wrap">
                <% if (item.color === 'green' || item.color === 'sage') { %>
                  <svg class="card-svg" viewBox="0 0 200 200" fill="none">
                    <circle cx="100" cy="100" r="60" stroke="rgba(245,240,232,0.08)" stroke-width="0.5"/>
                    <circle cx="100" cy="100" r="40" stroke="rgba(245,240,232,0.06)" stroke-width="0.5"/>
                    <path d="M100 40 Q130 70 100 100 Q70 130 100 160" stroke="rgba(168,196,181,0.15)" stroke-width="0.5" fill="none"/>
                    <path d="M100 40 Q70 70 100 100 Q130 130 100 160" stroke="rgba(168,196,181,0.15)" stroke-width="0.5" fill="none"/>
                    <line x1="60" y1="100" x2="140" y2="100" stroke="rgba(245,240,232,0.05)" stroke-width="0.5"/>
                    <line x1="100" y1="60" x2="100" y2="140" stroke="rgba(245,240,232,0.05)" stroke-width="0.5"/>
                  </svg>
                <% } else if (item.color === 'dark') { %>
                  <svg class="card-svg" viewBox="0 0 200 200" fill="none">
                    <rect x="60" y="60" width="80" height="80" stroke="rgba(245,240,232,0.07)" stroke-width="0.5" transform="rotate(45 100 100)"/>
                    <rect x="70" y="70" width="60" height="60" stroke="rgba(245,240,232,0.05)" stroke-width="0.5" transform="rotate(45 100 100)"/>
                    <line x1="100" y1="30" x2="100" y2="170" stroke="rgba(245,240,232,0.04)" stroke-width="0.5"/>
                    <line x1="30" y1="100" x2="170" y2="100" stroke="rgba(245,240,232,0.04)" stroke-width="0.5"/>
                  </svg>
                <% } else if (item.color === 'blush') { %>
                  <svg class="card-svg" viewBox="0 0 200 200" fill="none">
                    <circle cx="80" cy="90" r="35" stroke="rgba(28,28,26,0.06)" stroke-width="0.5"/>
                    <circle cx="120" cy="110" r="35" stroke="rgba(28,28,26,0.06)" stroke-width="0.5"/>
                    <path d="M65 60 Q100 40 135 60" stroke="rgba(28,28,26,0.08)" stroke-width="0.5" fill="none"/>
                    <path d="M65 140 Q100 160 135 140" stroke="rgba(28,28,26,0.08)" stroke-width="0.5" fill="none"/>
                  </svg>
                <% } else { %>
                  <svg class="card-svg" viewBox="0 0 200 200" fill="none">
                    <ellipse cx="100" cy="100" rx="55" ry="70" stroke="rgba(245,240,232,0.07)" stroke-width="0.5"/>
                    <path d="M100 30 L100 170" stroke="rgba(245,240,232,0.05)" stroke-width="0.5"/>
                    <path d="M60 65 Q100 45 140 65" stroke="rgba(168,196,181,0.1)" stroke-width="0.5" fill="none"/>
                    <path d="M60 135 Q100 155 140 135" stroke="rgba(168,196,181,0.1)" stroke-width="0.5" fill="none"/>
                  </svg>
                <% } %>
              </div>
              <!-- Wipe reveal curtain -->
              <div class="card-wipe"></div>
              <div class="card-img-label"><%= item.meta %></div>
              <div class="card-img-overlay">
                <p class="card-img-desc"><%= item.desc %></p>
                <a href="#" class="btn btn-ghost-sm">View Piece</a>
              </div>
            </div>
            <div class="card-body">
              <span class="badge badge--<%= item.badge.style %>"><%= item.badge.label %></span>
              <h3 class="card-title"><%= item.title %></h3>
              <p class="card-meta"><%= item.meta %></p>
              <div class="card-footer">
                <span class="card-price"><%= item.price %></span>
                <button class="card-btn" aria-label="Add to wishlist">♡</button>
              </div>
            </div>
          </article>
        <% }); %>
      </div>

      <div class="collection-cta">
        <a href="#" class="btn btn-secondary">View Full Collection</a>
      </div>
    </div>
  </section>

  <!-- ═══ LOOKBOOK — Horizontal Scroll ═══ -->
  <section class="lookbook" id="lookbook">
    <div class="lookbook-header">
      <p class="section-eyebrow"><%= content.lookbook.eyebrow %></p>
      <h2 class="section-title"><em><%= content.lookbook.title %></em></h2>
    </div>
    <div class="lookbook-track-wrap">
      <div class="lookbook-track" id="lookbook-track">
        <% content.lookbook.items.forEach(function(item, i) { %>
          <div class="lookbook-card lookbook-card--<%= item.color %>">
            <div class="lookbook-card-inner">
              <!-- Decorative SVG -->
              <svg class="lookbook-svg" viewBox="0 0 400 500" fill="none">
                <rect x="40" y="40" width="320" height="420" stroke="rgba(245,240,232,0.08)" stroke-width="0.5"/>
                <line x1="200" y1="40" x2="200" y2="460" stroke="rgba(245,240,232,0.04)" stroke-width="0.5"/>
                <circle cx="200" cy="250" r="80" stroke="rgba(168,196,181,0.06)" stroke-width="0.5"/>
              </svg>
              <div class="lookbook-card-content">
                <span class="lookbook-num"><%= String(i + 1).padStart(2, '0') %></span>
                <h3 class="lookbook-card-title"><%= item.title %></h3>
                <span class="lookbook-season"><%= item.season %></span>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ── Section Divider ── -->
  <div class="section-divider">
    <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
      <line class="divider-line" x1="0" y1="1" x2="1200" y2="1" stroke="currentColor" stroke-width="1"/>
    </svg>
  </div>

  <!-- ═══ EDITORIAL SPLIT ═══ -->
  <section class="editorial" id="editorial">
    <div class="editorial-inner">
      <div class="editorial-left">
        <p class="section-eyebrow"><%= content.editorial.eyebrow %></p>
        <blockquote class="editorial-quote"><%= content.editorial.quote %></blockquote>
        <cite class="editorial-cite"><%= content.editorial.cite %></cite>
      </div>
      <div class="editorial-right">
        <div class="editorial-panel">
          <div class="editorial-grain"></div>
          <div class="editorial-orb"></div>
          <p class="editorial-body"><%= content.editorial.body %></p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TESTIMONIALS ═══ -->
  <section class="testimonials-section">
    <div class="testimonials-inner">
      <p class="section-eyebrow center">Worn & Loved</p>
      <h2 class="section-title center">The Women <em>Behind the Drape</em></h2>

      <div class="testimonials-track-wrap">
        <div class="testimonials-track" id="testimonials-track">
          <% content.testimonials.forEach(function(t) { %>
            <div class="testimonial-card">
              <p class="testimonial-quote"><%= t.quote %></p>
              <div class="testimonial-author">
                <div class="testimonial-avatar"></div>
                <div>
                  <p class="testimonial-name"><%= t.author %></p>
                  <p class="testimonial-title"><%= t.title %></p>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
        <div class="testimonials-nav">
          <button class="t-nav-btn" id="t-prev">&#8592;</button>
          <div class="t-dots">
            <% content.testimonials.forEach(function(_, i) { %>
              <span class="t-dot <%= i === 0 ? 'active' : '' %>" data-idx="<%= i %>"></span>
            <% }); %>
          </div>
          <button class="t-nav-btn" id="t-next">&#8594;</button>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Section Divider ── -->
  <div class="section-divider">
    <svg viewBox="0 0 1200 2" preserveAspectRatio="none">
      <line class="divider-line" x1="0" y1="1" x2="1200" y2="1" stroke="currentColor" stroke-width="1"/>
    </svg>
  </div>

  <!-- ═══ PROCESS ═══ -->
  <section class="process-section" id="story">
    <div class="process-inner">
      <div class="process-header">
        <p class="section-eyebrow"><%= content.process.eyebrow %></p>
        <h2 class="section-title">
          <%= content.process.title %>
          <em class="script-heading"><%= content.process.titleAccent %></em>
        </h2>
      </div>

      <div class="process-steps">
        <% content.process.steps.forEach(function(step, i) { %>
          <div class="process-step">
            <div class="step-num"><%= step.num %></div>
            <div class="step-content">
              <h3 class="step-title"><%= step.title %></h3>
              <p class="step-body"><%= step.body %></p>
            </div>
            <% if (i < content.process.steps.length - 1) { %>
              <div class="step-connector"></div>
            <% } %>
          </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- ═══ NEWSLETTER ═══ -->
  <section class="newsletter" id="contact-form">
    <div class="newsletter-inner">
      <div class="newsletter-bg">
        <div class="newsletter-orb newsletter-orb-1"></div>
        <div class="newsletter-orb newsletter-orb-2"></div>
      </div>

      <p class="section-eyebrow center"><%= content.newsletter.eyebrow %></p>
      <h2 class="section-title center"><em><%= content.newsletter.title %></em></h2>
      <p class="section-subtitle center"><%= content.newsletter.subtitle %></p>

      <form class="newsletter-form" onsubmit="handleSubscribe(event)">
        <div class="newsletter-input-wrap">
          <input
            type="email"
            id="newsletter-email"
            placeholder="<%= content.newsletter.placeholder %>"
            aria-label="Email address"
            required
          >
          <button type="submit" class="btn btn-terracotta"><%= content.newsletter.cta %></button>
        </div>
        <p class="newsletter-note">No spam. Ever. Unsubscribe anytime.</p>
      </form>
    </div>
  </section>

</main>

<%- include('partials/footer') %>

<!-- Lenis Smooth Scroll -->
<script src="https://unpkg.com/lenis@1.1.18/dist/lenis.min.js"></script>

<!-- GSAP CDN -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollToPlugin.min.js"></script>

<!-- App JS -->
<script src="/js/main.js"></script>

</body>
</html>
