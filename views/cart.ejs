<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cart — <%= content.brand.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Great+Vibes&family=Instrument+Sans:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/shop.css">
</head>
<body class="no-loader">
<%- include('partials/nav') %>

<main class="cart-main">
  <div class="cart-inner">
    <div class="cart-header">
      <p class="section-eyebrow">Your Selection</p>
      <h1 class="cart-title">Shopping <em class="script-heading">Cart</em></h1>
    </div>

    <% if (items.length === 0) { %>
      <div class="cart-empty">
        <div class="cart-empty-icon">🛍</div>
        <p class="cart-empty-text">Your cart is empty.</p>
        <a href="/products" class="btn btn-terracotta">Browse Collection</a>
      </div>
    <% } else { %>
      <div class="cart-layout">
        <!-- Cart Items -->
        <div class="cart-items">
          <% items.forEach(function(item) { %>
            <div class="cart-item">
              <a href="/products/<%= item.id %>" class="cart-item-img-link">
                <img src="<%= item.image %>" alt="<%= item.title %>" class="cart-item-img">
              </a>
              <div class="cart-item-info">
                <span class="cart-item-category"><%= item.category %></span>
                <h3 class="cart-item-title"><a href="/products/<%= item.id %>"><%= item.title %></a></h3>
                <p class="cart-item-meta"><%= item.meta %></p>
                <p class="cart-item-unit-price">PKR <%= item.price.toLocaleString() %> each</p>

                <div class="cart-item-actions">
                  <form action="/cart/update" method="POST" class="cart-qty-form">
                    <input type="hidden" name="id" value="<%= item.id %>">
                    <button type="button" class="qty-btn qty-minus-btn">−</button>
                    <input type="number" name="qty" value="<%= item.qty %>" min="1" max="10" class="qty-input cart-qty-input" data-id="<%= item.id %>">
                    <button type="button" class="qty-btn qty-plus-btn">+</button>
                    <button type="submit" class="cart-update-btn">Update</button>
                  </form>
                  <form action="/cart/remove" method="POST">
                    <input type="hidden" name="id" value="<%= item.id %>">
                    <button type="submit" class="cart-remove-btn">Remove</button>
                  </form>
                </div>
              </div>
              <div class="cart-item-price">
                PKR <%= (item.price * item.qty).toLocaleString() %>
              </div>
            </div>
          <% }); %>
        </div>

        <!-- Order Summary -->
        <div class="cart-summary">
          <h2 class="cart-summary-title">Order Summary</h2>
          <div class="cart-summary-row">
            <span>Subtotal (<%= items.reduce((s,i) => s + i.qty, 0) %> items)</span>
            <span>PKR <%= total.toLocaleString() %></span>
          </div>
          <div class="cart-summary-row">
            <span>Shipping</span>
            <span class="cart-free-shipping">Free</span>
          </div>
          <div class="cart-summary-divider"></div>
          <div class="cart-summary-row cart-summary-total">
            <span>Total</span>
            <span>PKR <%= total.toLocaleString() %></span>
          </div>

          <a href="/checkout" class="btn btn-terracotta cart-checkout-btn">Proceed to Checkout</a>
          <a href="/products" class="cart-continue-link">← Continue Shopping</a>
        </div>
      </div>
    <% } %>
  </div>
</main>

<%- include('partials/footer') %>

<script>
  // Qty +/- buttons in cart
  document.querySelectorAll('.cart-item').forEach(item => {
    const input = item.querySelector('.cart-qty-input');
    item.querySelector('.qty-minus-btn')?.addEventListener('click', () => {
      if (input.value > 1) input.value = parseInt(input.value) - 1;
    });
    item.querySelector('.qty-plus-btn')?.addEventListener('click', () => {
      if (input.value < 10) input.value = parseInt(input.value) + 1;
    });
  });
</script>
</body>
</html>
