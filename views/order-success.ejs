<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Order Confirmed — <%= content.brand.name %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Great+Vibes&family=Instrument+Sans:ital,wght@0,300;0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <link rel="stylesheet" href="/css/shop.css">
</head>
<body class="no-loader">
<%- include('partials/nav') %>

<main class="success-main">
  <div class="success-inner">
    <div class="success-icon">✓</div>
    <p class="section-eyebrow center">Order Confirmed</p>
    <h1 class="success-title">Thank You, <em class="script-heading"><%= order.name.split(' ')[0] %></em></h1>
    <p class="success-subtitle">Your order has been placed successfully. We'll be in touch soon.</p>

    <div class="success-order-box">
      <div class="success-order-id">
        <span class="success-order-label">Order ID</span>
        <span class="success-order-value"><%= order.orderId %></span>
      </div>
      <div class="success-order-details">
        <div class="success-detail-row">
          <span>Email</span><span><%= order.email %></span>
        </div>
        <div class="success-detail-row">
          <span>Ship To</span><span><%= order.address %>, <%= order.city %></span>
        </div>
        <div class="success-detail-row">
          <span>Payment</span><span class="payment-method-badge"><%= order.paymentMethod === 'cod' ? 'Cash on Delivery' : order.paymentMethod === 'bank' ? 'Bank Transfer' : 'Credit/Debit Card' %></span>
        </div>
      </div>
    </div>

    <!-- Items Summary -->
    <div class="success-items">
      <h3 class="success-items-title">Items Ordered</h3>
      <% order.items.forEach(function(item) { %>
        <div class="checkout-item">
          <img src="<%= item.image %>" alt="<%= item.title %>" class="checkout-item-img">
          <div class="checkout-item-info">
            <p class="checkout-item-title"><%= item.title %></p>
            <p class="checkout-item-qty">Qty: <%= item.qty %></p>
          </div>
          <span class="checkout-item-price">PKR <%= (item.price * item.qty).toLocaleString() %></span>
        </div>
      <% }); %>
      <div class="success-total-row">
        <span>Order Total</span>
        <strong>PKR <%= order.total.toLocaleString() %></strong>
      </div>
    </div>

    <div class="success-actions">
      <a href="/products" class="btn btn-terracotta">Continue Shopping</a>
      <a href="/" class="btn btn-secondary">Back to Home</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
</body>
</html>
